# Port for the Node server to listen on
PORT=3000

# Environment (development, production)
NODE_ENV=development

# URL configs
FRONTEND_URL=http://localhost:3000
SOCKET_SERVER_URL=http://localhost:3000
NEXT_PUBLIC_SOCKET_SERVER_URL=http://localhost:3000

# Firebase Firestore Configuration
# Required: The project ID of your Firebase/Google Cloud project
FIREBASE_PROJECT_ID=your-firebase-project-id
# Optional: Local path to Firebase Service Account JSON credentials file
# If not specified, the SDK will fall back to standard Application Default Credentials (ADC) or the Emulator.
FIREBASE_SERVICE_ACCOUNT=./service-account.json

# Local Firestore Emulator (uncomment to test locally without connecting to real Firebase)
# FIRESTORE_EMULATOR_HOST=localhost:8080

# Security Secrets (JWT_SECRET must be at least 32 characters)
JWT_SECRET=your_jwt_secret_must_be_at_least_32_characters_long
ADMIN_SECRET=your_admin_secret_key

# Cloudinary Configs (For user photos and screenshot uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Brevo SMTP API Key (For sending emails)
BREVO_API_KEY=your_brevo_api_key
